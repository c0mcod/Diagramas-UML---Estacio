@startuml
title Diagrama de Componentes por Camadas - Versao Academica

rectangle "CAMADA DE APRESENTACAO" as Apresentacao  {
  component "Interface Web" as Web
}

rectangle "CAMADA DE APLICACAO (Controllers)" as Aplicacao  {
  component "Controlador\nSolicitacoes" as CtrlSol
  component "Controlador\nAutenticacao" as CtrlAuth
  component "Controlador\nCheck-in" as CtrlCheck
}

rectangle "CAMADA DE NEGOCIO (Services)" as Negocio  {
  component "Servico\nSolicitacoes" as SvcSol
  component "Servico\nAutenticacao" as SvcAuth
  component "Servico\nCheck-in" as SvcCheck
  component "Servico\nNotificacoes" as SvcNotif
  component "Servico\nGrupos" as SvcGrupo
  component "Servico\nDocumentos" as SvcDoc
}

rectangle "CAMADA DE DADOS" as Dados  {
  component "Banco de Dados\nRelacional" as DB
}

rectangle "SERVICOS EXTERNOS" as Externo  {
  component "Email" as Email
  component "WhatsApp\nAPI" as Zap
  component "Cloud\nStorage" as Storage
  component "Push" as Push
}

Web --> CtrlSol
Web --> CtrlAuth
Web --> CtrlCheck

CtrlSol --> SvcSol
CtrlAuth --> SvcAuth
CtrlCheck --> SvcCheck

SvcSol --> DB
SvcAuth --> DB
SvcCheck --> DB


SvcSol --> SvcNotif
SvcSol --> SvcGrupo
SvcSol --> SvcDoc

SvcNotif --> Email
SvcNotif --> Zap
SvcNotif --> Push
SvcGrupo --> Zap
SvcDoc --> Storage

actor Aluno
actor Professor
actor Secretaria

Aluno --> Web
Professor --> Web
Secretaria --> Web

@enduml
