@startuml
left to right direction
skinparam packageStyle rectangle

:Aluno: as aln
:Administração: as adm
:Secretaria: as sec
:Professor: as prof
:Coordenação: as coord

package Instituição {
    (Manter cadastros) as mc
    (Cadastrar usuário) as cu
    (Cadastrar aluno) as ca
    (Cadastrar professor) as cp
    (Cadastro de disciplinas) as cd
    (Cadastro de turmas) as ct
    (Gerar relatórios) as gr
    (Notificar alunos) as na
    (Realizar login) as login
}

package AlunoInterface {
    (Registrar solicitação) as rs
    (Anexar documento) as anxDoc
    (Acompanhar solicitação) as acomp
    (Solicitar meio de notificação preferida) as solicNotif
    (Escolher notificação por email) as emailNotif
    (Escolher notificação por SMS) as smsNotif
    (Escolher notificação por push) as pushNotif
}

package SecretariaInterface {
    (Validar documentação) as validDoc
    (Encaminhar solicitação) as encSol
}

package CoordenacaoInterface {
    (Analisar solicitação) as analise
    (Deferir solicitação) as aprovSol
    (Indeferir solicitação) as reprSol
}

package ProfessorInterface {
    (Responder solicitação) as resSol
    (Realizar check-in) as checkin
    (Registrar horário de chegada) as regChegada
    (Visualizar registro de ponto) as viewPonto
    (Verificar sala prevista) as verifSala
    (Confirmar sala correta) as confSalaOk
    (Reportar sala incorreta) as reportSalaErrada
    (Solicitar realocação de sala) as solicRealocacao
}

adm --> mc
adm --> gr

sec --> validDoc
sec --> encSol
sec --> na
sec --> gr

coord --> cd
coord --> ct
coord --> analise
coord --> na
coord --> gr

prof --> resSol
prof --> gr
prof --> checkin

aln --> rs
aln --> anxDoc
aln --> acomp
aln --> login
aln --> solicNotif

ca -|> cu
cp -|> cu
cd -|> mc
ct -|> mc
cu -|> mc

encSol ..> validDoc : <<include>>

anxDoc ..> rs : <<extend>>

aprovSol ..> analise : <<extend>>
reprSol ..> analise : <<extend>>

solicNotif ..> emailNotif : <<extend>>
solicNotif ..> smsNotif : <<extend>>
solicNotif ..> pushNotif : <<extend>>

checkin ..> regChegada : <<extend>>
checkin ..> viewPonto : <<extend>>
checkin ..> verifSala : <<include>>

verifSala ..> confSalaOk : <<extend>>
verifSala ..> reportSalaErrada : <<extend>>

reportSalaErrada ..> solicRealocacao : <<include>>

note top of verifSala
  O professor deve verificar se a sala
  disponível corresponde à sala prevista
  no horário agendado
end note

note top of login
  Login é pré-requisito para
  acesso a todos os outros
  casos de uso do sistema
end note

@enduml
